{
  "manifest_version": 3,
  "name": "arXiv Classic Red",
  "version": "0.4.0",
  "description": "Restores the classic red arXiv header. Click the toolbar icon to toggle. CSS-only styling, no tracking, no network requests. Not affiliated with arXiv.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["scripting", "storage"],
  "host_permissions": [
    "https://arxiv.org/*",
    "https://www.arxiv.org/*",
    "https://info.arxiv.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "arXiv Classic Red: on (click to toggle)"
  }
}
